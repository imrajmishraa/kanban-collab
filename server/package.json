{
  "name": "kanban-collaboration-server",
  "version": "1.0.0",
  "description": "Enterprise Kanban Collaboration Platform Backend REST & WS Sync Server",
  "main": "dist/interfaces/http/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/interfaces/http/app.js",
    "dev": "nodemon --watch src -e ts --exec ts-node src/interfaces/http/app.ts",
    "dev:ws": "nodemon --watch src -e ts --exec ts-node src/interfaces/websocket/servers/y-ws-server.ts",
    "test": "jest --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.0.9",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-mongo-sanitize": "^2.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "pino": "^8.19.0",
    "redis": "^4.6.13",
    "ws": "^8.16.0",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsdom": "^21.1.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "multer": "^2.2.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^10.3.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "zod": "^4.4.3"
  }
}
